APP_NAME=Secure Workspace Fabric
APP_VERSION=0.1.0

DATABASE_URL=postgresql://swf_user:swf_password@postgres:5432/swf_db

SECRET_KEY=dev-secret-key
MASTER_KEK=0123456789abcdef0123456789abcdef
LOCAL_STORAGE_PATH=storage

SYNTHETIC_AGENT_INTERVAL_SECONDS=30
SYNTHETIC_AGENT_MAX_FILES=50

STORAGE_BACKEND=minio

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=swf_minio
MINIO_SECRET_KEY=swf_minio_password
MINIO_BUCKET=swf-artifacts
MINIO_SECURE=false